{
    "name": "Supporter",
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Nom complet"
      },
      "phone": {
        "type": "string",
        "description": "Num\u00e9ro WhatsApp"
      },
      "canton": {
        "type": "string",
        "enum": [
          "figuil",
          "lam",
          "biou",
          "bidzar_1",
          "bidzar_2"
        ],
        "description": "Canton ou village"
      },
      "village": {
        "type": "string",
        "description": "Village sp\u00e9cifique"
      },
      "help_type": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "mobilisation",
            "communication",
            "logistique",
            "terrain"
          ]
        },
        "description": "Types d'aide propos\u00e9s"
      },
      "profile": {
        "type": "string",
        "enum": [
          "jeune",
          "femme",
          "agriculteur",
          "eleveur",
          "commercant",
          "enseignant",
          "autre"
        ],
        "description": "Profil du supporter"
      },
      "email": {
        "type": "string",
        "description": "Email (optionnel)"
      },
      "contacted": {
        "type": "boolean",
        "default": false,
        "description": "D\u00e9j\u00e0 contact\u00e9 par l'\u00e9quipe"
      }
    },
    "required": [
      "name",
      "phone",
      "canton"
    ]
  }